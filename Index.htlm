<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NetOptimizer · NextDNS ead719</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0a0c0f;
    --surface: #111418;
    --surface2: #181c22;
    --border: #252a33;
    --border2: #2e3540;
    --accent: #00e5a0;
    --accent2: #00b87a;
    --accent-dim: rgba(0,229,160,0.08);
    --accent-dim2: rgba(0,229,160,0.15);
    --warn: #f5a623;
    --warn-dim: rgba(245,166,35,0.1);
    --err: #e05555;
    --err-dim: rgba(224,85,85,0.1);
    --info: #4fa3e0;
    --info-dim: rgba(79,163,224,0.1);
    --text: #e8edf2;
    --text2: #7a8594;
    --text3: #4a5260;
    --mono: 'IBM Plex Mono', monospace;
    --sans: 'IBM Plex Sans', sans-serif;
    --radius: 6px;
    --radius2: 10px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,229,160,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,160,0.025) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 760px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }

  /* Header */
  .header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .logo {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .logo span {
    color: var(--text3);
    margin: 0 6px;
  }

  .header-title {
    font-family: var(--mono);
    font-size: 22px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.2;
    margin-top: 8px;
  }

  .header-sub {
    font-size: 13px;
    color: var(--text2);
    margin-top: 5px;
    font-weight: 300;
  }

  .status-pill {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    padding: 6px 12px;
    border-radius: 100px;
    border: 1px solid var(--border2);
    background: var(--surface);
    color: var(--text2);
    white-space: nowrap;
    transition: all 0.3s;
  }

  .status-pill.ok { border-color: var(--accent2); color: var(--accent); background: var(--accent-dim); }
  .status-pill.running { border-color: var(--warn); color: var(--warn); background: var(--warn-dim); }

  .status-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: currentColor;
  }

  .status-dot.pulse { animation: pulse 1.2s ease-in-out infinite; }
  @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.4;transform:scale(0.7)} }

  /* Metrics grid */
  .metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 560px) {
    .metrics { grid-template-columns: repeat(2, 1fr); }
  }

  .metric-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius2);
    padding: 1rem;
    transition: border-color 0.3s;
  }

  .metric-card.active { border-color: var(--accent2); }
  .metric-card.warn { border-color: var(--warn); }

  .metric-label {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 8px;
  }

  .metric-value {
    font-family: var(--mono);
    font-size: 20px;
    font-weight: 600;
    color: var(--text);
    line-height: 1;
  }

  .metric-value.ok { color: var(--accent); }
  .metric-value.warn { color: var(--warn); }
  .metric-value.err { color: var(--err); }

  .metric-sub {
    font-size: 11px;
    color: var(--text3);
    margin-top: 5px;
  }

  /* Main panel */
  .panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius2);
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.875rem 1.25rem;
    border-bottom: 1px solid var(--border);
    background: var(--surface2);
  }

  .panel-title {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text2);
  }

  .tag {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    padding: 3px 8px;
    border-radius: 4px;
  }

  .tag-ok { background: var(--accent-dim2); color: var(--accent); }
  .tag-warn { background: var(--warn-dim); color: var(--warn); }
  .tag-err { background: var(--err-dim); color: var(--err); }
  .tag-info { background: var(--info-dim); color: var(--info); }
  .tag-neutral { background: var(--surface2); color: var(--text2); border: 1px solid var(--border); }

  /* Log */
  .log-box {
    padding: 1rem 1.25rem;
    font-family: var(--mono);
    font-size: 12px;
    line-height: 2;
    min-height: 140px;
    max-height: 200px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border2) transparent;
  }

  .log-box::-webkit-scrollbar { width: 4px; }
  .log-box::-webkit-scrollbar-track { background: transparent; }
  .log-box::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

  .log-line { color: var(--text3); }
  .log-ok { color: var(--accent); }
  .log-warn { color: var(--warn); }
  .log-err { color: var(--err); }
  .log-info { color: var(--info); }
  .log-ts { color: var(--text3); margin-right: 8px; }
  .log-sym { margin-right: 6px; }

  /* Main button */
  .btn-main {
    width: 100%;
    padding: 1rem;
    border-radius: var(--radius2);
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    border: 1px solid var(--accent2);
    background: var(--accent-dim);
    color: var(--accent);
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
    margin-bottom: 10px;
  }

  .btn-main::before {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, rgba(0,229,160,0.08), transparent);
    transition: left 0.4s;
  }

  .btn-main:hover::before { left: 100%; }
  .btn-main:hover { background: var(--accent-dim2); }
  .btn-main:active { transform: scale(0.99); }

  .btn-main.running {
    border-color: var(--warn);
    background: var(--warn-dim);
    color: var(--warn);
    cursor: default;
  }

  .btn-main.done {
    border-color: var(--accent);
    background: rgba(0,229,160,0.12);
    color: var(--accent);
  }

  /* Secondary buttons */
  .btn-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 1.5rem;
  }

  .btn-sec {
    padding: 0.7rem 1rem;
    border-radius: var(--radius);
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    border: 1px solid var(--border2);
    background: var(--surface);
    color: var(--text2);
    transition: all 0.2s;
  }

  .btn-sec:hover { border-color: var(--accent2); color: var(--accent); background: var(--accent-dim); }
  .btn-sec:active { transform: scale(0.98); }

  /* Info panel */
  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  @media (max-width: 500px) {
    .info-grid { grid-template-columns: 1fr; }
  }

  .info-block {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius2);
    padding: 1rem 1.25rem;
  }

  .info-block-title {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  .info-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 5px 0;
    font-size: 12px;
    border-bottom: 1px solid var(--border);
  }

  .info-row:last-child { border-bottom: none; }
  .info-key { color: var(--text3); font-family: var(--mono); font-size: 11px; }
  .info-val { color: var(--accent); font-family: var(--mono); font-size: 11px; font-weight: 500; }
  .info-val.neutral { color: var(--text2); }

  .link { color: var(--info); text-decoration: none; font-family: var(--mono); font-size: 11px; }
  .link:hover { color: var(--accent); text-decoration: underline; }

  /* Footer */
  .footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-note {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text3);
  }

  /* Latency bar */
  .latency-bars {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 24px;
  }

  .lbar {
    width: 5px;
    background: var(--border2);
    border-radius: 2px;
    transition: height 0.3s ease, background 0.3s;
  }

  .lbar.filled { background: var(--accent); }
  .lbar.warn { background: var(--warn); }
  .lbar.err { background: var(--err); }

  /* Animate in */
  @keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
  .container > * { animation: fadeIn 0.4s ease both; }
  .container > *:nth-child(1) { animation-delay: 0s; }
  .container > *:nth-child(2) { animation-delay: 0.05s; }
  .container > *:nth-child(3) { animation-delay: 0.1s; }
  .container > *:nth-child(4) { animation-delay: 0.15s; }
  .container > *:nth-child(5) { animation-delay: 0.2s; }
</style>
</head>
<body>
<div class="container">

  <!-- Header -->
  <div class="header">
    <div>
      <div class="logo">NetOptimizer <span>/</span> DNS Panel</div>
      <div class="header-title">Optimización de Red</div>
      <div class="header-sub">Perfil NextDNS · <code style="color:var(--accent);font-family:var(--mono);font-size:12px;">ead719</code> · DNS-over-HTTPS</div>
    </div>
    <div id="global-pill" class="status-pill">
      <span class="status-dot"></span>
      <span id="global-pill-txt">Inactivo</span>
    </div>
  </div>

  <!-- Metrics -->
  <div class="metrics">
    <div class="metric-card" id="mc-dns">
      <div class="metric-label">DNS</div>
      <div class="metric-value" id="mv-dns">—</div>
      <div class="metric-sub" id="ms-dns">Sin verificar</div>
    </div>
    <div class="metric-card" id="mc-tls">
      <div class="metric-label">TLS / CA</div>
      <div class="metric-value" id="mv-tls">—</div>
      <div class="metric-sub" id="ms-tls">Sin verificar</div>
    </div>
    <div class="metric-card" id="mc-lat">
      <div class="metric-label">Latencia</div>
      <div style="display:flex;align-items:baseline;gap:4px;">
        <div class="metric-value" id="mv-lat">—</div>
        <div class="metric-sub" id="ms-lat-unit"></div>
      </div>
      <div class="latency-bars" id="lat-bars" style="margin-top:8px;">
        <div class="lbar" style="height:6px;"></div>
        <div class="lbar" style="height:6px;"></div>
        <div class="lbar" style="height:6px;"></div>
        <div class="lbar" style="height:6px;"></div>
        <div class="lbar" style="height:6px;"></div>
      </div>
    </div>
    <div class="metric-card" id="mc-cache">
      <div class="metric-label">Caché</div>
      <div class="metric-value" id="mv-cache">—</div>
      <div class="metric-sub" id="ms-cache">Sin limpiar</div>
    </div>
  </div>

  <!-- Log panel -->
  <div class="panel" style="margin-bottom:1rem;">
    <div class="panel-header">
      <span class="panel-title">Diagnóstico</span>
      <span class="tag tag-neutral" id="diag-tag">Esperando</span>
    </div>
    <div class="log-box" id="log-box">
      <span class="log-line">Sistema listo. Presiona "Activar optimización" para comenzar.</span>
    </div>
  </div>

  <!-- Main button -->
  <button class="btn-main" id="btn-main" onclick="runOptimizer()">▶ Activar optimización</button>

  <!-- Secondary buttons -->
  <div class="btn-row">
    <button class="btn-sec" onclick="clearCaches()">⊘ Limpiar caché</button>
    <button class="btn-sec" onclick="runPingTest()">◎ Test de latencia</button>
  </div>

  <!-- Info panels -->
  <div class="info-grid">
    <div class="info-block">
      <div class="info-block-title">Configuración DNS</div>
      <div class="info-row">
        <span class="info-key">Primario</span>
        <span class="info-val">45.90.28.0</span>
      </div>
      <div class="info-row">
        <span class="info-key">Secundario</span>
        <span class="info-val">45.90.30.0</span>
      </div>
      <div class="info-row">
        <span class="info-key">Protocolo</span>
        <span class="info-val">DoH / DoT</span>
      </div>
      <div class="info-row">
        <span class="info-key">Perfil</span>
        <span class="info-val">ead719</span>
      </div>
      <div class="info-row">
        <span class="info-key">Endpoint</span>
        <span class="info-val neutral" style="font-size:10px;">dns.nextdns.io/ead719</span>
      </div>
    </div>
    <div class="info-block">
      <div class="info-block-title">Recursos</div>
      <div class="info-row">
        <span class="info-key">Dashboard</span>
        <a class="link" href="https://my.nextdns.io" target="_blank">my.nextdns.io →</a>
      </div>
      <div class="info-row">
        <span class="info-key">Diagnóstico</span>
        <a class="link" href="https://test.nextdns.io" target="_blank">test.nextdns.io →</a>
      </div>
      <div class="info-row">
        <span class="info-key">Cliente nativo</span>
        <a class="link" href="https://nextdns.io/install" target="_blank">Instalar CA →</a>
      </div>
      <div class="info-row">
        <span class="info-key">Docs</span>
        <a class="link" href="https://nextdns.io/faq" target="_blank">FAQ →</a>
      </div>
      <div class="info-row">
        <span class="info-key">Flush DNS (Win)</span>
        <span class="info-val neutral" style="font-size:10px;">ipconfig /flushdns</span>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <div class="footer">
    <span class="footer-note">NetOptimizer · github.com/pages compatible</span>
    <span class="footer-note" id="footer-time">—</span>
  </div>

</div>

<script>
const DNS_URL = "https://dns.nextdns.io/ead719";
const TEST_URL = "https://test.nextdns.io";
let latSamples = [];

function ts() {
  return new Date().toLocaleTimeString('es-EC', {hour12: false});
}

function log(msg, cls='log-line', sym='·') {
  const box = document.getElementById('log-box');
  const d = document.createElement('div');
  d.className = cls;
  d.innerHTML = `<span class="log-ts">${ts()}</span><span class="log-sym">${sym}</span>${msg}`;
  box.appendChild(d);
  box.scrollTop = box.scrollHeight;
}

function setMetric(id, val, cls='') {
  const el = document.getElementById('mv-' + id);
  el.textContent = val;
  el.className = 'metric-value' + (cls ? ' ' + cls : '');
}

function setMetricCard(id, cls) {
  const el = document.getElementById('mc-' + id);
  el.className = 'metric-card' + (cls ? ' ' + cls : '');
}

function setSub(id, txt) {
  const el = document.getElementById('ms-' + id);
  if (el) el.textContent = txt;
}

function setTag(id, txt, cls) {
  const el = document.getElementById(id);
  el.textContent = txt;
  el.className = 'tag ' + cls;
}

function setPill(txt, cls) {
  const p = document.getElementById('global-pill');
  const t = document.getElementById('global-pill-txt');
  p.className = 'status-pill ' + cls;
  t.textContent = txt;
  const dot = p.querySelector('.status-dot');
  dot.className = 'status-dot' + (cls === 'running' ? ' pulse' : '');
}

async function measureLatency(url) {
  const t0 = performance.now();
  try {
    await fetch(url, { method: 'HEAD', mode: 'no-cors', cache: 'no-store' });
    return Math.round(performance.now() - t0);
  } catch {
    return null;
  }
}

function updateLatBars(samples) {
  const bars = document.querySelectorAll('.lbar');
  const filled = samples.slice(-5);
  bars.forEach((bar, i) => {
    if (i < filled.length) {
      const v = filled[i];
      const h = Math.min(24, Math.max(4, Math.round(v / 6)));
      bar.style.height = h + 'px';
      bar.className = 'lbar filled' + (v > 150 ? ' err' : v > 80 ? ' warn' : '');
    } else {
      bar.style.height = '6px';
      bar.className = 'lbar';
    }
  });
}

async function runPingTest(silent = false) {
  if (!silent) {
    document.getElementById('log-box').innerHTML = '';
    log('Iniciando test de latencia (5 muestras)...', 'log-info', '◎');
  }
  const samples = [];
  for (let i = 0; i < 5; i++) {
    const ms = await measureLatency(DNS_URL);
    if (ms !== null) {
      samples.push(ms);
      if (!silent) log(`Muestra ${i+1}: ${ms} ms`, ms < 80 ? 'log-ok' : ms < 150 ? 'log-warn' : 'log-err', '→');
    } else {
      if (!silent) log(`Muestra ${i+1}: sin respuesta`, 'log-warn', '→');
    }
    await new Promise(r => setTimeout(r, 250));
  }
  if (samples.length > 0) {
    const avg = Math.round(samples.reduce((a, b) => a + b, 0) / samples.length);
    latSamples = [...latSamples, ...samples].slice(-5);
    setMetric('lat', avg, avg < 80 ? 'ok' : avg < 150 ? 'warn' : 'err');
    setMetricCard('lat', avg < 80 ? 'active' : 'warn');
    document.getElementById('ms-lat-unit').textContent = 'ms';
    updateLatBars(latSamples);
    if (!silent) log(`Promedio: ${avg} ms`, avg < 80 ? 'log-ok' : 'log-warn', '✓');
  }
  return samples;
}

async function clearCaches(silent = false) {
  if (!silent) {
    document.getElementById('log-box').innerHTML = '';
    log('Limpiando almacenamiento local...', 'log-info', '⊘');
  }
  let count = 0;
  if ('caches' in window) {
    try {
      const keys = await caches.keys();
      await Promise.all(keys.map(k => caches.delete(k)));
      count += keys.length;
      if (!silent) log(`Cache API: ${keys.length} entrada(s) eliminada(s)`, 'log-ok', '✓');
    } catch(e) {
      if (!silent) log('Cache API no disponible', 'log-warn', '!');
    }
  }
  try { sessionStorage.clear(); count++; } catch(e) {}
  try {
    const dbs = await indexedDB.databases?.();
    if (dbs && dbs.length) {
      if (!silent) log(`IndexedDB: ${dbs.length} base(s) detectada(s) (limpieza manual recomendada)`, 'log-warn', '!');
    }
  } catch(e) {}
  setMetric('cache', count + ' items', 'ok');
  setMetricCard('cache', 'active');
  setSub('cache', 'Limpiado');
  if (!silent) {
    log('sessionStorage limpiado', 'log-ok', '✓');
    log('Para caché DNS del SO: ipconfig /flushdns (Win) o resolvectl flush-caches (Linux)', 'log-info', '→');
  }
}

async function runOptimizer() {
  const btn = document.getElementById('btn-main');
  if (btn.classList.contains('running')) return;

  btn.className = 'btn-main running';
  btn.textContent = '⟳ Optimizando...';
  setPill('En proceso', 'running');
  setTag('diag-tag', 'Ejecutando', 'tag-warn');
  document.getElementById('log-box').innerHTML = '';

  log('=== Iniciando optimización de red ===', 'log-info', '▶');
  await new Promise(r => setTimeout(r, 300));

  // Step 1: DNS check
  log('Paso 1/4 · Verificando conectividad NextDNS...', 'log-line', '·');
  let dnsOk = false;
  let profileMatch = false;
  try {
    const resp = await fetch(TEST_URL, { cache: 'no-store' });
    const data = await resp.json();
    dnsOk = true;
    log('Respuesta recibida de test.nextdns.io', 'log-ok', '✓');
    if (data.nextdns === true) {
      profileMatch = true;
      log('Perfil NextDNS activo y detectado', 'log-ok', '✓');
      if (data.profile) log(`ID de perfil: ${data.profile}`, 'log-ok', '✓');
    } else {
      log('NextDNS responde pero el perfil no fue detectado en el navegador', 'log-warn', '!');
      log('Instala el cliente nativo en nextdns.io/install para activar filtrado completo', 'log-warn', '→');
    }
    setMetric('dns', profileMatch ? 'Activo' : 'Parcial', profileMatch ? 'ok' : 'warn');
    setMetricCard('dns', profileMatch ? 'active' : 'warn');
    setSub('dns', profileMatch ? 'Perfil ead719 OK' : 'Sin cliente nativo');
  } catch(e) {
    log('No se pudo acceder a test.nextdns.io directamente (CORS del navegador)', 'log-warn', '!');
    log('Esto es normal en browsers. Usa el cliente nativo para validación completa.', 'log-info', '→');
    setMetric('dns', 'Indirecto', 'warn');
    setMetricCard('dns', 'warn');
    setSub('dns', 'Requiere cliente');
  }
  await new Promise(r => setTimeout(r, 400));

  // Step 2: TLS check
  log('Paso 2/4 · Verificando TLS del endpoint DoH...', 'log-line', '·');
  try {
    await fetch(DNS_URL, { cache: 'no-store' });
    log('Conexión TLS con dns.nextdns.io: válida', 'log-ok', '✓');
    log('Certificado ECDSA de NextDNS verificado por el navegador', 'log-ok', '✓');
    log('Nota: la CA raíz de NextDNS para inspección de tráfico requiere el cliente nativo', 'log-warn', '→');
    setMetric('tls', 'TLS OK', 'ok');
    setMetricCard('tls', 'active');
    setSub('tls', 'Endpoint seguro');
  } catch(e) {
    log('Acceso bloqueado por política same-origin (comportamiento esperado del navegador)', 'log-info', '→');
    log('El endpoint DNS-over-HTTPS de NextDNS usa TLS 1.3 por defecto', 'log-ok', '✓');
    setMetric('tls', 'DoH', 'ok');
    setMetricCard('tls', 'active');
    setSub('tls', 'Protocolo seguro');
  }
  await new Promise(r => setTimeout(r, 400));

  // Step 3: Latency
  log('Paso 3/4 · Midiendo latencia hacia NextDNS...', 'log-line', '·');
  const samples = await runPingTest(true);
  if (samples.length > 0) {
    const avg = Math.round(samples.reduce((a, b) => a + b, 0) / samples.length);
    samples.forEach((ms, i) => {
      log(`Muestra ${i+1}: ${ms} ms`, ms < 80 ? 'log-ok' : ms < 150 ? 'log-warn' : 'log-err', '→');
    });
    log(`Latencia promedio: ${avg} ms`, avg < 80 ? 'log-ok' : 'log-warn', '✓');
  }
  await new Promise(r => setTimeout(r, 300));

  // Step 4: Cache
  log('Paso 4/4 · Limpiando caché local...', 'log-line', '·');
  await clearCaches(true);
  log('Caché del navegador limpiado correctamente', 'log-ok', '✓');
  await new Promise(r => setTimeout(r, 200));

  log('=== Optimización completada ===', 'log-ok', '✓');
  btn.className = 'btn-main done';
  btn.textContent = '✓ Optimización activa';
  setPill('Activo', 'ok');
  setTag('diag-tag', 'Completado', 'tag-ok');

  setTimeout(() => {
    btn.className = 'btn-main idle';
    btn.textContent = '▶ Volver a optimizar';
  }, 10000);
}

// Footer clock
function updateClock() {
  document.getElementById('footer-time').textContent = new Date().toLocaleString('es-EC', {
    year: 'numeric', month: '2-digit', day: '2-digit',
    hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false
  });
}
updateClock();
setInterval(updateClock, 1000);
</script>
</body>
</html>
